{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "iTeam",
  "description": "Manual do iTeam — crie e gerencie sua força de trabalho de IA. Agentes que executam operações reais do seu negócio, com segurança, 24 horas por dia.",
  "colors": {
    "primary": "#7c5cfc",
    "light": "#9b82fc",
    "dark": "#5a3fd6"
  },
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "favicon": "https://media.brand.dev/e03294f6-0b5e-4074-ada6-8c284c64c285.png",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Início",
          "icon": "house",
          "href": "/"
        },
        {
          "anchor": "Site do iTeam",
          "icon": "globe",
          "href": "https://iteam.works"
        }
      ]
    },
    "directory": "card",
    "tabs": [
      {
        "tab": "Documentação",
        "groups": [
          {
            "group": "Começando",
            "icon": "rocket",
            "expanded": true,
            "pages": [
              "pt/introducao",
              "pt/primeiros-passos",
              "pt/conceitos"
            ]
          },
          {
            "group": "Conversar",
            "icon": "messages-square",
            "expanded": true,
