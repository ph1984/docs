            "icon": "workflow",
            "expanded": true,
            "pages": [
              "en/automation/task-board",
              "en/automation/processes"
            ]
          },
          {
            "group": "Administration",
            "icon": "shield",
            "expanded": true,
            "pages": [
              "en/administration/security-and-access",
              "en/administration/settings"
            ]
          }
        ]
      }
