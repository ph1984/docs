              "pt/conversar/assistente-iteam",
              "pt/conversar/widgets"
            ]
          },
          {
            "group": "Inteligência",
            "icon": "brain",
            "expanded": true,
            "pages": [
              "pt/inteligencia/agentes",
              "pt/inteligencia/times-de-agentes"
            ]
          },
          {
            "group": "Recursos",
            "icon": "boxes",
            "expanded": true,
            "pages": [
              "pt/recursos/skills",
              "pt/recursos/apis",
              "pt/recursos/fontes-de-dados",
              "pt/recursos/atlas-do-recurso",
              "pt/recursos/estatisticas",
              "pt/recursos/uso"
            ]
          },
          {
            "group": "Automação",
            "icon": "workflow",
            "expanded": true,
            "pages": [
              "pt/automacao/quadro-de-tarefas",
              "pt/automacao/processos"
            ]
          },
          {
            "group": "Administração",
            "icon": "shield",
            "expanded": true,
            "pages": [
              "pt/administracao/seguranca-e-acessos",
              "pt/administracao/configuracoes"
            ]
          }
        ]
      },
      {
        "tab": "English",
        "groups": [
          {
            "group": "Get Started",
            "icon": "rocket",
            "expanded": true,
            "pages": [
              "en/introduction",
              "en/getting-started",
              "en/concepts"
            ]
          },
          {
            "group": "Chat",
            "icon": "messages-square",
            "expanded": true,
            "pages": [
              "en/chat/chat-with-agents",
              "en/chat/iteam-assistant",
              "en/chat/widgets"
            ]
          },
          {
            "group": "Intelligence",
            "icon": "brain",
            "expanded": true,
